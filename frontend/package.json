{
  "name": "cef-frontend",
  "private": true,
  "version": "0.1.0",
  "description": "Frontend workspace for the CEF Filter Proxy — Bun + Turborepo + Next.js dashboard.",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "biome check .",
    "format": "biome format --write .",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "packageManager": "bun@1.1.7"
}
