
APP_NAME="CEF Filter Proxy"
APP_ENV="development"
DEBUG="true"

LOG_LEVEL="DEBUG"
LOG_JSON="false"
LOG_PER_EVENT="true"

LISTEN_HOST="0.0.0.0"
LISTEN_PORT="5514"
MAX_DATAGRAM_BYTES="65535"

ELK_HOST="127.0.0.1"
ELK_PORT="5140"

DEFAULT_POLICY="forward"
SEED_RULES_PATH="config/rules.example.yaml"

DATABASE_URL="postgresql+asyncpg://cef:cef@localhost:5432/cef"
DB_AUTO_CREATE="true"
EVENT_PERSIST="true"

API_HOST="0.0.0.0"
API_PORT="8080"
CORS_ALLOW_ORIGINS='["http://localhost:3000","http://127.0.0.1:3000"]'

EVENT_BUFFER_SIZE="500"

RATE_LIMIT_PER_SOURCE_PER_SEC="0"
